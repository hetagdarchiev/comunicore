{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "cross-env NEXT_PUBLIC_API_BASE_URL=http://localhost:8080 next dev",
    "dev:prod": "cross-env NEXT_PUBLIC_API_BASE_URL=https://comunicore.mooo.com next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit --incremental false --pretty",
    "prepare": "husky",
    "generate-api": "openapi-ts",
    "postinstall": "npm run generate-api"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.100.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "highlight.js": "^11.11.1",
    "immer": "^11.1.8",
    "isomorphic-dompurify": "^3.5.1",
    "markdown-it": "^14.1.1",
    "next": "16.1.7",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@dreamsicle.io/stylelint-config-tailwindcss": "^1.2.2",
    "@hey-api/openapi-ts": "^0.94.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-fsd-lint": "^1.0.10",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "msw": "^2.15.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^17.3.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1",
    "typescript": "^5"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}